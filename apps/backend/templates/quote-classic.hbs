{{!
  Template PDF de orçamento — quote-classic.hbs
  Preset: Clássico (D-06) — layout formal/serifado, moldura, ornamentação discreta.

  Variáveis de empresa disponíveis neste template:
    empresaNome       — ex: "Minha Empresa Grafica & Papelaria LTDA"
    empresaCnpj       — ex: "00.000.000/0001-00"
    empresaEndereco   — ex: "Rua Principal, 100 — Centro · Cidade / SP · CEP 00000-000"
    empresaLogoUrl    — URL pública do logo (ausente = sem tag <img>; nunca use fallback de URL externa)
    empresaCor        — cor primária hex, ex: "#0d6efd" (usada com moderação como cor de destaque)
    empresaTelefones  — ex: "(12) 99999-9999 · (12) 3333-4444" (ausente = linha omitida)
    empresaEmail      — ex: "orcamento@minhaempresa.com.br" (ausente = linha omitida)
    empresaInstagram  — ex: "@minhaempresa" (ausente = linha omitida)

  Variáveis de orçamento:
    idorcamento, dataorcamento
    cliente.nome, cliente.telefone, cliente.email
    vendedorNome, validade, prazoEntrega, condicaoPagamento, observacoes
    itens[].sequenciaitem, .produto.descricaoproduto, .produto.descricaocurta, .quantidadeitem, .valoritem, .orcamentovalorfinalitem
    carimbos.itens[].numero, .carimbo, .dimensoes, .descricao
    totais.valor, totais.desconto
    pencilsTopUrl, pencilsBottomUrl (decorativos — este preset clássico não os renderiza visualmente nas faixas, mas aceita a variável para compatibilidade entre presets)

  Contato da empresa (D-07): empresaTelefones, empresaEmail, empresaInstagram são injetados
  pelo serviço via EMPRESA_TELEFONES / EMPRESA_EMAIL / EMPRESA_INSTAGRAM no .env do deploy.
  Linhas omitidas quando a variável estiver ausente/vazia.

  Sem links externos: fontes do sistema (Liberation Serif, presente no Dockerfile Chromium).
  Ícones via SVG inline — sem dependência de CDN (anti-regressão Pitfall 2).
}}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Orçamento Nº {{idorcamento}} — {{empresaNome}}</title>
<!-- Sem links externos: fontes do sistema (Liberation Serif, presente no Dockerfile Chromium bookworm) -->
<!-- Icones via SVG inline — sem dependencia de CDN (anti-regressao Pitfall 2) -->
<style>
  @page { size: A4; margin: 0; }
  :root {
    --primary: {{empresaCor}};
    --ink:#1f1a14; --ink-soft:#5c5346; --ink-faint:#8c8273;
    --line:#cbbfa8; --line-soft:#e7e0d2;
    --paper:#fbf8f1;
  }
  *{box-sizing:border-box;-webkit-print-color-adjust:exact;print-color-adjust:exact}
  /* Fonte primaria: Liberation Serif (fonts-liberation, presente no Dockerfile Chromium bookworm) */
  html,body{margin:0;padding:0;font-family:'Liberation Serif','Times New Roman',Georgia,serif;color:var(--ink);background:#fff;font-size:10.8pt;line-height:1.5;-webkit-font-smoothing:antialiased}
  .num{font-variant-numeric:tabular-nums}
  .icon-svg{width:11px;height:11px;display:inline-block;vertical-align:middle;fill:currentColor}

  .page{padding:16mm 16mm;border:1px solid var(--line)}
  .page-inner{border:1px solid var(--line-soft);padding:10mm}

  /* Header */
  .doc-header{display:grid;grid-template-columns:auto 1fr auto;gap:16px;align-items:flex-start;padding-bottom:14px;border-bottom:2px double var(--ink);margin-bottom:16px}
  .doc-header__logo{width:78px;height:78px;object-fit:contain;background:#fff;border:1px solid var(--line);padding:5px}
  .doc-header__co h1{margin:0 0 6px;font-size:14pt;font-weight:700;line-height:1.2;letter-spacing:.01em;color:var(--ink);font-style:normal}
  .doc-header__co .cnpj{font-size:8.3pt;font-weight:400;color:var(--ink-soft);margin-bottom:8px;font-style:italic}
  .doc-header__co .cnpj b{color:var(--ink);font-weight:700;font-style:normal}

  .contact-list{display:grid;grid-template-columns:auto 1fr;gap:5px 8px;font-size:8.3pt;line-height:1.3;color:var(--ink-soft)}
  .contact-list .icon{width:15px;height:15px;border:1px solid var(--primary);border-radius:50%;color:var(--primary);display:inline-flex;align-items:center;justify-content:center}
  .contact-list .icon svg{width:9px;height:9px;display:block;fill:var(--primary)}

  .doc-header__id{text-align:right;min-width:128px;border:1px solid var(--ink);padding:10px 14px}
  .doc-header__id-label{font-size:7.5pt;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-faint);font-style:italic}
  .doc-header__id-num{font-size:20pt;font-weight:700;letter-spacing:0;margin:6px 0 4px;font-variant-numeric:tabular-nums;color:var(--ink)}
  .doc-header__id-date{font-size:8.5pt;font-weight:400;line-height:1.2;color:var(--ink-soft)}

  /* Customer */
  .customer{border:1px solid var(--line);border-left:3px solid var(--primary);padding:12px 15px;margin-bottom:14px;background:var(--paper)}
  .customer__to{font-size:7.5pt;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-faint);font-style:italic;margin-bottom:6px}
  .customer__name{font-size:13pt;font-weight:700;line-height:1.2;color:var(--ink);margin:0 0 6px}
  .customer__meta{font-size:8.8pt;line-height:1.5;color:var(--ink-soft)}
  .customer__meta b{color:var(--ink);font-weight:700;margin-right:4px}
  .intro{margin:0 0 16px;font-size:9.3pt;line-height:1.55;color:var(--ink-soft);font-style:italic}

  /* Section labels */
  .section-label{display:flex;align-items:center;justify-content:space-between;margin:16px 0 8px;gap:10px}
  .section-label h2{margin:0;font-size:9pt;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--ink);border-bottom:1px solid var(--primary);padding-bottom:4px;flex:1}
  .section-label .hint{font-size:7.8pt;color:var(--ink-faint);font-style:italic}

  /* Items table */
  .items{width:100%;border-collapse:collapse;font-size:9pt;line-height:1.4}
  .items thead th{font-size:7.8pt;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--ink);background:var(--paper);text-align:left;padding:8px 7px;border-top:1px solid var(--ink);border-bottom:1px solid var(--ink)}
  .items thead th.num{text-align:right}
  .items thead th.center{text-align:center}
  .items tbody td{padding:8px 7px;border-bottom:1px solid var(--line-soft);vertical-align:top;color:var(--ink)}
  .items tbody td.num{text-align:right;font-variant-numeric:tabular-nums}
  .items tbody td.center{text-align:center}
  .items tbody td.idx{color:var(--ink-soft);font-size:8.6pt;font-weight:700;width:20px}
  .items tbody .desc-strong{font-weight:700;color:var(--ink)}
  .items tbody .desc-sub{font-size:8pt;line-height:1.3;color:var(--ink-soft);margin-top:2px;display:block;font-style:italic}
  .items tbody td.total{font-weight:700;color:var(--ink)}

  /* Stamps */
  .stamps__grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:6px}
  .stamp{border:1px solid var(--line);padding:10px 12px;background:var(--paper);display:flex;flex-direction:column;min-height:90px;page-break-inside:avoid}
  .stamp__num{font-size:7.5pt;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-faint);font-style:italic}
  .stamp__body{font-size:10pt;font-weight:700;line-height:1.4;color:var(--ink);margin:6px 0;white-space:pre-wrap;text-align:center;flex:1;display:flex;align-items:center;justify-content:center}
  .stamp__foot{display:flex;justify-content:space-between;font-size:8pt;font-weight:400;color:var(--ink-soft);border-top:1px solid var(--line-soft);padding-top:6px;margin-top:auto}
  .stamp__dim{color:var(--ink-faint);font-size:7.5pt}
  .stamp__model{color:var(--ink-soft)}

  /* Obs + totals */
  .foot-row{display:grid;grid-template-columns:1fr 270px;gap:12px;margin-top:16px;align-items:stretch}
  .obs{background:var(--paper);padding:12px 14px;border:1px solid var(--line)}
  .obs__label{font-size:7.5pt;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-faint);font-style:italic;margin-bottom:6px}
  .obs__body{font-size:9pt;line-height:1.5;color:var(--ink);white-space:pre-wrap}
  .obs__body--empty{color:var(--ink-faint);font-style:italic}

  .totals{border:1px solid var(--ink);padding:14px 16px;display:flex;flex-direction:column;gap:7px;color:var(--ink);background:var(--paper)}
  .totals__row{display:flex;justify-content:space-between;align-items:baseline;font-size:9pt;font-weight:400;line-height:1.2;color:var(--ink-soft)}
  .totals__row b{color:var(--ink);font-weight:700;font-variant-numeric:tabular-nums}
  .totals__row--disc b{color:var(--primary)}
  .totals__row--grand{border-top:1px double var(--ink);margin-top:6px;padding-top:10px}
  .totals__row--grand span{font-size:8pt;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink)}
  .totals__row--grand b{font-size:16pt;font-weight:700;color:var(--primary);letter-spacing:0}

  /* Conditions */
  .conds{display:grid;grid-template-columns:repeat(4,1fr);gap:0;margin-top:10px;border:1px solid var(--line)}
  .cond{padding:9px 12px;border-right:1px solid var(--line)}
  .cond:last-child{border-right:none}
  .cond__label{font-size:7pt;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-faint);font-style:italic;margin-bottom:4px}
  .cond__value{font-size:9.5pt;font-weight:700;line-height:1.2;color:var(--ink)}

  /* Sign-off */
  .signoff{margin-top:18px;font-size:9pt;line-height:1.5;color:var(--ink-soft);font-style:italic}
  .signoff b{color:var(--ink);font-weight:700;font-style:normal}
</style>
</head>
<body>

<div class="page">
<div class="page-inner">

  <header class="doc-header">
    {{#if empresaLogoUrl}}<img src="{{empresaLogoUrl}}" class="doc-header__logo" alt="{{empresaNome}}">{{/if}}

    <div class="doc-header__co">
      <h1>{{empresaNome}}</h1>
      <div class="cnpj"><b>CNPJ</b> {{empresaCnpj}}</div>
      <div class="contact-list">
        <!-- geo-alt-fill — SVG inline, sem CDN -->
        <span class="icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg></span>
        <span>{{empresaEndereco}}</span>
        {{#if empresaTelefones}}
        <!-- telephone-fill — SVG inline, sem CDN -->
        <span class="icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M1.885.511a1.745 1.745 0 0 1 2.61.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.678.678 0 0 0 .178.643l2.457 2.457a.678.678 0 0 0 .644.178l2.189-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511z"/></svg></span>
        <span>{{empresaTelefones}}</span>
        {{/if}}
        {{#if empresaEmail}}
        <!-- envelope-fill — SVG inline, sem CDN -->
        <span class="icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555zM0 4.697v7.104l5.803-3.558L0 4.697zM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757zm3.436-.586L16 11.801V4.697l-5.803 3.546z"/></svg></span>
        <span>{{empresaEmail}}</span>
        {{/if}}
        {{#if empresaInstagram}}
        <!-- instagram — SVG inline, sem CDN -->
        <span class="icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.478 2.478 0 0 1-.92-.598 2.48 2.48 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233 0-2.136.008-2.388.046-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.92-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334z"/></svg></span>
        <span>{{empresaInstagram}}</span>
        {{/if}}
      </div>
    </div>

    <div class="doc-header__id">
      <div class="doc-header__id-label">Orçamento</div>
      <div class="doc-header__id-num">Nº {{idorcamento}}</div>
      <div class="doc-header__id-date">{{dataorcamento}}</div>
    </div>
  </header>

  <div class="customer">
    <div class="customer__to">Para</div>
    <h2 class="customer__name">{{cliente.nome}}</h2>
    <div class="customer__meta">
      {{#if cliente.telefone}}<b>Telefone</b> {{cliente.telefone}}{{/if}}
      {{#if cliente.email}} &nbsp;·&nbsp; <b>E-mail</b> {{cliente.email}}{{/if}}
    </div>
  </div>

  <p class="intro">
    Prezado cliente, apresentamos nossa proposta comercial para sua avaliação.
    Estamos à disposição para qualquer esclarecimento adicional.
  </p>

  <div class="section-label">
    <h2>Itens da proposta</h2>
    <div class="hint">valores em BRL</div>
  </div>

  <table class="items">
    <thead>
      <tr>
        <th class="idx">#</th>
        <th>Descrição</th>
        <th class="center">Qtd</th>
        <th class="num">Valor unit.</th>
        <th class="num">Valor original</th>
        <th class="num">Total</th>
      </tr>
    </thead>
    <tbody>
      {{#each itens}}
      <tr>
        <td class="idx">{{sequenciaitem}}</td>
        <td>
          <span class="desc-strong">{{produto.descricaoproduto}}</span>
          {{#if produto.descricaocurta}}<span class="desc-sub">{{produto.descricaocurta}}</span>{{/if}}
        </td>
        <td class="center">{{quantidadeitem}}</td>
        <td class="num">{{valoritem}}</td>
        <td class="num">{{orcamentovalorfinalitem}}</td>
        <td class="num total">{{orcamentovalorfinalitem}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  {{#if carimbos.itens.length}}
  <div class="section-label">
    <h2>Visualização de carimbos</h2>
    <div class="hint">aprovação visual</div>
  </div>
  <div class="stamps__grid">
    {{#each carimbos.itens}}
    <div class="stamp">
      <div class="stamp__num">Carimbo {{numero}}</div>
      <div class="stamp__body">{{descricao}}</div>
      <div class="stamp__foot">
        <span class="stamp__dim">{{dimensoes}}</span>
        <span class="stamp__model">{{carimbo}}</span>
      </div>
    </div>
    {{/each}}
  </div>
  {{/if}}

  <div class="foot-row">
    <div class="obs">
      <div class="obs__label">Observações</div>
      <div class="obs__body{{#unless observacoes}} obs__body--empty{{/unless}}">{{#if observacoes}}{{observacoes}}{{else}}Sem observações.{{/if}}</div>
    </div>
    <div class="totals">
      <div class="totals__row"><span>Valor original</span><b>{{totais.valor}}</b></div>
      <div class="totals__row totals__row--disc"><span>Desconto</span><b>{{#if totais.desconto}}{{totais.desconto}}{{else}}Isento{{/if}}</b></div>
      <div class="totals__row totals__row--grand"><span>Total</span><b>{{totais.valor}}</b></div>
    </div>
  </div>

  <div class="section-label">
    <h2>Condições</h2>
  </div>
  <div class="conds">
    <div class="cond">
      <div class="cond__label">Vendedor</div>
      <div class="cond__value">{{vendedorNome}}</div>
    </div>
    <div class="cond">
      <div class="cond__label">Validade</div>
      <div class="cond__value">{{validade}}</div>
    </div>
    <div class="cond">
      <div class="cond__label">Prazo de entrega</div>
      <div class="cond__value">{{prazoEntrega}}</div>
    </div>
    <div class="cond">
      <div class="cond__label">Pagamento</div>
      <div class="cond__value">{{condicaoPagamento}}</div>
    </div>
  </div>

  <p class="signoff">
    Estamos à disposição e aguardamos seu retorno.<br>
    <b>Atenciosamente, equipe {{empresaNome}}.</b>
  </p>

</div>
</div>
</body>
</html>
