generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DataSource {
  MANUAL
  PDV
  CHATWOOT
}

enum PriceSource {
  MANUAL
  PDV
}

enum QuoteStatus {
  PENDENTE
  PAGAMENTO_PARCIAL
  APROVADO
  EM_PRODUCAO
  PRONTO_PARA_ENTREGA
  ENTREGUE
  ENVIADO
  CANCELADO
}

enum UserRole {
  VENDEDOR
  ATENDENTE
  ADMIN
}

enum ExternalSystem {
  PDV
  CHATWOOT
}

model Customer {
  id                String   @id @default(uuid())
  fullName          String
  phone             String?
  email             String?
  source            DataSource @default(MANUAL)
  chatwootContactId BigInt?   @db.BigInt
  isAssociated Boolean @default(false)
  quotes            Quote[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([phone])
  @@index([email])
}

model User {
  id            String               @id @default(uuid())
  name          String
  email         String?              @unique
  role          UserRole             @default(VENDEDOR)
  isActive      Boolean              @default(true)
  createdQuotes Quote[]              @relation("QuoteCreatedBy")
  statusChanges QuoteStatusHistory[] @relation("StatusChangedBy")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model Quote {
  id                 String               @id @default(uuid())
  internalNumber     Int                  @unique @default(autoincrement())
  externalQuoteId    BigInt?              @db.BigInt @unique
  customerId         String
  createdById        String?
  status             QuoteStatus           @default(PENDENTE)
  source             DataSource            @default(MANUAL)
  sellerExternalId   BigInt?               @db.BigInt
  saleExternalId     BigInt?               @db.BigInt
  sellerName         String?
  conversationId     BigInt?               @db.BigInt
  chatwootContactId  BigInt?               @db.BigInt
  paymentSource      String?
  paymentMethod      String?
  paymentExternalId  String?               @unique
  paymentEventId     String?               @unique
  paymentAmount      Decimal?              @db.Decimal(12, 2)
  paymentDiscount    Decimal               @default(0) @db.Decimal(12, 2)
  paidTotal          Decimal               @default(0) @db.Decimal(12, 2)
  pendingTotal       Decimal               @default(0) @db.Decimal(12, 2)
  firstInstallmentAmount Decimal?          @db.Decimal(12, 2)
  secondInstallmentAmount Decimal?         @db.Decimal(12, 2)
  secondInstallmentExternalId String?      @unique
  paymentConfirmedAt DateTime?
  paymentFailedAt    DateTime?
  paymentFailureReason String?
  paymentNote        String?
  validity           String?
  deliveryDate       DateTime?
  paymentTerms       String?
  notes              String?
  budgetDate         DateTime?
  editedAt           DateTime?
  subtotal           Decimal               @default(0) @db.Decimal(12, 2)
  discount           Decimal               @default(0) @db.Decimal(12, 2)
  surcharge          Decimal               @default(0) @db.Decimal(12, 2)
  total              Decimal               @default(0) @db.Decimal(12, 2)
  customer           Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy          User?                 @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  items              QuoteItem[]
  stamps             QuoteStampItem[]
  statusHistory      QuoteStatusHistory[]
  documents          QuoteDocument[]
  paymentTransactions PaymentTransaction[]
  approvalToken       String?
  approvalRequestedAt DateTime?
  approvalExpiresAt   DateTime?
  approved            Boolean               @default(false)
  approvedAt          DateTime?
  nfseNumero          String?
  nfseCodigoVerificacao String?
  nfseLink            String?
  nfseEmitidaEm       DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([status, updatedAt])
  
  @@index([conversationId])
  @@index([chatwootContactId])
  @@index([saleExternalId])
  @@index([paymentSource, paymentMethod])
  @@index([paymentConfirmedAt])
}

model PaymentTransaction {
  id            String   @id @default(uuid())
  quoteId       String
  externalId    String?  @unique
  eventId       String?  @unique
  source        String
  method        String
  status        String
  amount        Decimal  @db.Decimal(12, 2)
  metadata      Json?
  webhookPayload Json?
  processedAt   DateTime @default(now())
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, processedAt])
  @@index([source, method, status])
}

model QuoteItem {
  id                String      @id @default(uuid())
  quoteId           String
  parentItemId      String?
  sequence          Int
  externalItemId    BigInt?     @db.BigInt
  productExternalId BigInt?     @db.BigInt
  reference         String?
  shortDescription  String
  description       String
  quantity          Decimal     @db.Decimal(10, 2)
  unitPrice         Decimal     @db.Decimal(12, 2)
  discount          Decimal     @default(0) @db.Decimal(12, 2)
  finalPrice        Decimal     @db.Decimal(12, 2)
  priceSource       PriceSource @default(MANUAL)
  quote             Quote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  parentItem        QuoteItem?  @relation("QuoteItemChildren", fields: [parentItemId], references: [id], onDelete: SetNull)
  children          QuoteItem[] @relation("QuoteItemChildren")
  createdAt         DateTime    @default(now())

  @@index([quoteId, sequence])
  @@index([parentItemId])
}

model QuoteStampItem {
  id          String   @id @default(uuid())
  quoteId     String
  number      Int
  stampType   String
  dimensions  String?
  description String?
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([quoteId, number])
}

model QuoteStatusHistory {
  id            String      @id @default(uuid())
  quoteId       String
  oldStatus     QuoteStatus?
  newStatus     QuoteStatus
  changedById   String?
  changedByName String
  changedAt     DateTime    @default(now())
  quote         Quote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  changedBy     User?       @relation("StatusChangedBy", fields: [changedById], references: [id])
}

model QuoteDocument {
  id           String   @id @default(uuid())
  quoteId      String
  fileName     String
  contentType  String
  storagePath  String
  publicUrl    String?  @db.Text
  generatedBy  String
  generatedAt  DateTime @default(now())
  quote        Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, generatedAt])
}

model ExternalReference {
  id             String         @id @default(uuid())
  entityType     String
  entityId       String
  externalSystem ExternalSystem
  externalId     String
  createdAt      DateTime       @default(now())

  @@index([externalSystem, externalId])
  @@unique([externalSystem, externalId, entityType])
}

model CobrancaBoleto {
  id             Int                    @id @default(autoincrement())
  txidEfi        String?
  idclienteAthos Int
  valor          Decimal                @db.Decimal(12, 2)
  status         String                 @default("pendente")
  linkBoleto     String?
  pixPayload     String?
  nomeArquivo    String?
  expireAt       String?
  criadoEm       DateTime               @default(now())
  atualizadoEm   DateTime               @updatedAt
  titulos        CobrancaBoletoTitulo[]
}

model CobrancaBoletoTitulo {
  id               Int            @id @default(autoincrement())
  cobrancaBoletoId Int
  idcontareceber   Int
  valor            Decimal        @db.Decimal(12, 2)
  cobrancaBoleto   CobrancaBoleto @relation(fields: [cobrancaBoletoId], references: [id])

  @@index([cobrancaBoletoId])
  @@index([idcontareceber])
}

model NfseEmitida {
  id             Int                 @id @default(autoincrement())
  numeroNfse     String?
  numeroRps      Int
  idclienteAthos Int
  valorServico   Decimal             @db.Decimal(12, 2)
  linkNfse       String?             // link de download da NFS-e retornado pela API IIBR
  dataEmissao    DateTime            @default(now())
  criadoEm       DateTime            @default(now())
  idvenda        Int?                // D-07: venda Athos que originou a NFS-e
  titulos        NfseEmitidaTitulo[]

  @@index([idvenda])                 // D-23: busca eficiente de duplicidade por venda
}

model NfseEmitidaTitulo {
  id             Int         @id @default(autoincrement())
  nfseEmitidaId  Int
  idcontareceber Int
  valor          Decimal     @db.Decimal(12, 2)
  nfseEmitida    NfseEmitida @relation(fields: [nfseEmitidaId], references: [id])

  @@index([nfseEmitidaId])
  @@index([idcontareceber])
}

enum PdfTemplateKind {
  PRESET
  CUSTOM
}

// PdfTemplate: armazena templates Handlebars/HTML para geração de PDF de orçamento.
// Unicidade do ativo (no máximo um isActive=true por deploy) é garantida por transação
// no serviço (Plano 05), não por constraint de banco — Postgres não tem partial unique
// trivial via Prisma para campo boolean.
model PdfTemplate {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  source    String          @db.Text
  kind      PdfTemplateKind
  isActive  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([isActive])
}
