# ============================================================
# Frontend — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha com os valores
# corretos para o seu deploy.
# ============================================================

# URL base da API backend (Next.js Route Handlers)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ============================================================
# Identidade da Empresa (White-Label)
# Baked at build: todas as vars NEXT_PUBLIC_* são incluídas no
# bundle JS e visíveis para o cliente — use somente dados públicos.
# ============================================================

# Nome da empresa exibido no header e no título da aba
NEXT_PUBLIC_EMPRESA_NOME=Bom Custo Papelaria & Gráfica Rápida

# CNPJ da empresa (exibido no header; oculto se vazio)
NEXT_PUBLIC_EMPRESA_CNPJ=62.391.927/0001-57

# Endereço da empresa (exibido no header; oculto se vazio)
NEXT_PUBLIC_EMPRESA_ENDERECO=Ilhabela - SP, CEP: 11633-078

# E-mail de contato da empresa (exibido no header; oculto se vazio)
NEXT_PUBLIC_EMPRESA_EMAIL=orcamento@bomcustoilhabela.com.br

# URL do logo da empresa (fallback: /media/logo-primary.png)
NEXT_PUBLIC_EMPRESA_LOGO_URL=/media/logo-primary.png

# Cor primária da empresa em formato hexadecimal (fallback: #0d6efd)
# Define a custom property CSS --cor-primaria usada em todo o sistema
NEXT_PUBLIC_EMPRESA_COR_PRIMARIA=#0d6efd
