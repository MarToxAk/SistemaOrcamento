# Backend
PORT=4000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# PostgreSQL principal
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bomcusto

POSTGRES_USER=postgres
POSTGRES_PASSWORD=trocar-senha
POSTGRES_DB=bomcusto

# Banco do PDV (somente leitura na V1)
PDV_DB_URL=postgresql://readonly:readonly@localhost:5433/pdv
PDV_DB_SCHEMA=public
PDV_DB_READONLY_USER=usuario_leitura
PDV_DB_READONLY_PASSWORD=trocar-senha

# Banco Athos (somente leitura)
ATHOS_PG_HOST=192.168.3.198
ATHOS_PG_DB=athos
ATHOS_PG_USER=usuario_leitura
ATHOS_PG_PASS=trocar-senha
ATHOS_PG_PORT=5432

# Token para autenticação em endpoints Athos (deixe vazio para desativar)
ATHOS_API_TOKEN=

# Frontend (API Route proxy) -> backend NestJS
BACKEND_URL=http://localhost:4000/api

# Chatwoot
CHATWOOT_BASE_URL=https://SEU_CHATWOOT
CHATWOOT_API_TOKEN=trocar-token
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1

# MinIO / S3 compativel para PDFs
MINIO_ENDPOINT=minio.seudominio.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=SEU_ACCESS_KEY
MINIO_SECRET_KEY=SEU_SECRET_KEY
MINIO_BUCKET=orcamento
MINIO_REGION=us-east-1
MINIO_PUBLIC_BASE_URL=https://minio.seudominio.com
MINIO_PATH_PREFIX=quotes

# Efi Pay (Pix / Cobranças)
EFI_BASE_URL=https://pix.api.efipay.com.br
EFI_COBRANCA_BASE_URL=https://cobrancas.api.efipay.com.br
EFI_CLIENT_ID=SEU_CLIENT_ID
EFI_CLIENT_SECRET=SEU_CLIENT_SECRET
EFI_PIX_KEY=SUA_CHAVE_PIX

# Certificado PEM — escolha UMA das opções abaixo:
# Opção 1: Texto PEM direto (mais simples para Docker/produção)
# Cole o conteúdo do .pem substituindo cada quebra de linha por \n
# Exemplo: EFI_CERT_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
EFI_CERT_PEM=
EFI_KEY_PEM=

# NFS-e (Prefeitura de Ilhabela — iiBrasil)
# Token de produção — em homologação o token de teste já está embutido no código
NFSE_TOKEN=SEU_TOKEN_NFSE
