п»ї# Backend
PORT=4000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# PostgreSQL principal
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bomcusto

POSTGRES_USER=postgres
POSTGRES_PASSWORD=trocar-senha
POSTGRES_DB=bomcusto

# Banco do PDV (somente leitura na V1)
PDV_DB_URL=postgresql://readonly:readonly@localhost:5433/pdv
PDV_DB_SCHEMA=public
PDV_DB_READONLY_USER=usuario_leitura
PDV_DB_READONLY_PASSWORD=trocar-senha

# Banco Athos (somente leitura; para escrita de produto usar usuario com INSERT/UPDATE em produto)
ATHOS_PG_HOST=192.168.3.198
ATHOS_PG_DB=athos
ATHOS_PG_USER=usuario_leitura
ATHOS_PG_PASS=trocar-senha
ATHOS_PG_PORT=5432

# ID do usuario Athos que representa o Sistema de Orcamento (integer).
# Deve ser um idfuncionariousuario valido da tabela funcionario_usuario no banco Athos.
# Usado como idusuariocadastro e idusuarioalteracao nas operacoes de escrita de produto.
ATHOS_SISTEMA_USUARIO_ID=

# Token para autenticaГѓВ§ГѓВЈo em endpoints Athos (deixe vazio para desativar)
ATHOS_API_TOKEN=

# Frontend (API Route proxy) -> backend NestJS
BACKEND_URL=http://localhost:4000/api

# Chatwoot
CHATWOOT_BASE_URL=https://SEU_CHATWOOT
CHATWOOT_API_TOKEN=trocar-token
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1

# MinIO / S3 compativel para PDFs
MINIO_ENDPOINT=minio.seudominio.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=SEU_ACCESS_KEY
MINIO_SECRET_KEY=SEU_SECRET_KEY
MINIO_BUCKET=orcamento
MINIO_REGION=us-east-1
MINIO_PUBLIC_BASE_URL=https://minio.seudominio.com
MINIO_PATH_PREFIX=quotes

# Efi Pay (Pix / CobranГѓВ§as)
EFI_BASE_URL=https://pix.api.efipay.com.br
EFI_COBRANCA_BASE_URL=https://cobrancas.api.efipay.com.br
EFI_CLIENT_ID=SEU_CLIENT_ID
EFI_CLIENT_SECRET=SEU_CLIENT_SECRET
EFI_PIX_KEY=SUA_CHAVE_PIX

# Certificado PEM Гўв‚¬вЂќ escolha UMA das opГѓВ§ГѓВµes abaixo:
# OpГѓВ§ГѓВЈo 1: Texto PEM direto (mais simples para Docker/produГѓВ§ГѓВЈo)
# Cole o conteГѓВєdo do .pem substituindo cada quebra de linha por \n
# Exemplo: EFI_CERT_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
EFI_CERT_PEM=
EFI_KEY_PEM=

# NFS-e (Prefeitura de Ilhabela Гўв‚¬вЂќ iiBrasil)
# Token de produГѓВ§ГѓВЈo Гўв‚¬вЂќ em homologaГѓВ§ГѓВЈo o token de teste jГѓВЎ estГѓВЎ embutido no cГѓВіdigo
NFSE_TOKEN=SEU_TOKEN_NFSE
NFSE_CNPJ_PRESTADOR=SEU_CNPJ_PRESTADOR
NFSE_INSCRICAO_MUNICIPAL=SUA_INSCRICAO_MUNICIPAL
NFSE_SOAP_URL=https://ilhabela2.iibr.com.br/rps/3520400/1/soap/producao/rps
NFSE_AUX_URL=https://ilhabela2.iibr.com.br/rps/3520400/2/AUXILIARRPS
# Empresa (White-Label)
# Dados exibidos no PDF de orcamento e no XML da NFS-e.
# Para customizar, edite estes valores no .env do seu deploy.
# EMPRESA_NOME e EMPRESA_CNPJ tambem aparecem no cabecalho do PDF gerado.
EMPRESA_NOME=Bom Custo Papelaria & Grafica Rapida LTDA
EMPRESA_CNPJ=62.391.927/0001-57
EMPRESA_ENDERECO=Rua Olimpio Leite da Silva, 39 - Loja 07, PerequГЄ В· Ilhabela / SP В· CEP 11633-078
# Codigo IBGE do municipio do prestador de servico (obrigatorio para NFS-e)
EMPRESA_MUNICIPIO_IBGE=3520400

# URL publica do logo da empresa (opcional вЂ” sem definicao, o logo e omitido do PDF sem imagem quebrada)
# EMPRESA_LOGO_URL=https://seudominio.com/logo.png

# Cor primaria da marca em hex (opcional вЂ” fallback: #0d6efd azul Bootstrap)
# EMPRESA_COR_PRIMARIA=#0d6efd

# Caminho para template PDF customizado (opcional вЂ” fallback: template padrao do sistema)
# Pode ser montado via volume Docker: -v /host/meu-template.hbs:/app/apps/backend/templates/custom.hbs
# EMPRESA_PDF_TEMPLATE_PATH=/app/apps/backend/templates/custom.hbs

# ATENCAO para deploy em outro municipio: definir tambem NFSE_SOAP_URL e NFSE_AUX_URL
# com as URLs do provedor NFS-e do municipio (os defaults apontam para Ilhabela/iiBrasil)
# Seguranca interna
# Chave para autenticacao entre servicos internos (gere com: openssl rand -hex 32)
INTERNAL_API_KEY=trocar-chave-segura
# Gerenciamento de templates PDF (tela admin)
# Chave usada APENAS para proteger os endpoints de upload/ativar/excluir/preview de templates.
# Sem ela definida, todos os endpoints de escrita de template retornam 401.
# Gerar com: openssl rand -hex 32
# ATENCAO: NUNCA usar prefixo NEXT_PUBLIC_ вЂ” esta chave deve ser exclusivamente server-side.
ADMIN_API_KEY=trocar-chave-admin-segura


# Segredo para validar webhooks da EFI Pay (configure no painel EFI -> Webhooks -> Secret)
EFI_WEBHOOK_SECRET=trocar-segredo-webhook

# Origens permitidas para CORS (separadas por virgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Tailscale (deploy VPS)
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx

