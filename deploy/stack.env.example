# Tailscale
TS_AUTHKEY=

# Imagens (obrigatorio se nao trocar o fallback no compose)
BACKEND_IMAGE=ghcr.io/martoxak/orcamento-backend:latest
FRONTEND_IMAGE=ghcr.io/martoxak/orcamento-frontend:latest

# Postgres (servico interno da stack)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque_essa_senha
POSTGRES_DB=orcamento

# Backend
NODE_ENV=production
PORT=4000
APP_BASE_URL=https://seu-dominio.com
DATABASE_URL=postgresql://postgres:troque_essa_senha@postgres:5432/orcamento
WAIT_FOR_DB_TIMEOUT_MS=120000
WAIT_FOR_DB_INTERVAL_MS=2000

# Integracoes
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=

ATHOS_PG_HOST=
ATHOS_PG_DB=
ATHOS_PG_USER=
ATHOS_PG_PASS=
ATHOS_PG_PORT=5432

# ID do usuario Athos que representa o Sistema de Orcamento (integer).
# Deve ser um idfuncionariousuario valido da tabela funcionario_usuario no banco Athos.
# Usado como idusuariocadastro e idusuarioalteracao nas operacoes de escrita de produto.
ATHOS_SISTEMA_USUARIO_ID=

# SMB/Samba — credenciais para montar o share de anexos do Athos em Docker
# O share //192.168.3.203/html/Anexo/contapagar é montado em /mnt/samba/contapagar
SMB_USER=
SMB_PASS=
SMB_DOMAIN=WORKGROUP
ATHOS_SMB_HOST_MOUNT_PATH=/mnt/samba/contapagar
ATHOS_SMB_MOUNT_PATH=/mnt/samba/contapagar

PDV_DB_URL=
PDV_DB_SCHEMA=public
PDV_DB_READONLY_USER=
PDV_DB_READONLY_PASSWORD=

# MinIO
MINIO_ENDPOINT=
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=orcamento
MINIO_REGION=us-east-1
MINIO_PUBLIC_BASE_URL=
MINIO_PATH_PREFIX=quotes

# EFI Bank
BACKEND_URL=https://seu-dominio.com/api
EFI_BASE_URL=https://pix.api.efipay.com.br
EFI_COBRANCA_BASE_URL=https://cobrancas.api.efipay.com.br
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_PIX_KEY=
EFI_CERT_PEM=
EFI_KEY_PEM=
INTERNAL_API_KEY=
EFI_WEBHOOK_SECRET=

# NFS-e (iiBrasil - Prefeitura de Ilhabela)
NFSE_TOKEN=

# Contato de empresa (opcionais; sem elas a linha some no PDF e no header do site)
# EMPRESA_TELEFONES: telefones de contato (string livre). Alimenta o rodape do PDF E o
#   header das paginas web. ex: (12) 99648-4918 · (12) 3896-1474
# EMPRESA_WHATSAPP: numero (somente digitos, com DDI) usado nos links "Fale conosco" (wa.me)
#   das paginas de status/aprovacao do cliente. Sem ele, o bloco de contato some. ex: 5512996484918
# EMPRESA_EMAIL: email de contato  ex: orcamento@suaempresa.com.br
# EMPRESA_INSTAGRAM: handle do Instagram (somente PDF)  ex: @suaempresa
EMPRESA_TELEFONES=
EMPRESA_WHATSAPP=
EMPRESA_EMAIL=
EMPRESA_INSTAGRAM=

# Frontend
BACKEND_URL=http://ts-webserver2:4000/api

# Painel Admin de Templates PDF (server-side; consumido por backend e frontend)
# ADMIN_API_KEY: mesma chave nos dois containers. Gerar: openssl rand -hex 32
# CONFIG_PANEL_PASSWORD: senha do painel /configuracoes/templates (fail-open se vazia!)
# CONFIG_PANEL_SESSION_SECRET: segredo do cookie de sessao (fallback p/ ADMIN_API_KEY se vazio)
ADMIN_API_KEY=
CONFIG_PANEL_PASSWORD=
CONFIG_PANEL_SESSION_SECRET=
